# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# ===== Supabase server (bắt buộc cho đăng ký + thanh toán tự động) =====
# Lấy tại: Supabase Dashboard > Project Settings > API > service_role
# TUYỆT ĐỐI không để lộ key này ra client / commit lên git.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===== SePay — thanh toán chuyển khoản tự động (https://sepay.vn) =====
# Chuỗi bí mật tự đặt, cấu hình trùng khớp trong SePay > Webhooks > API Key
SEPAY_WEBHOOK_API_KEY=your_random_webhook_api_key

# Tuỳ chọn: ghi đè thông tin tài khoản nhận tiền trong config/payment.ts
# SEPAY_BANK_CODE=ACB
# SEPAY_ACCOUNT_NUMBER=your_bank_account_number
# SEPAY_ACCOUNT_NAME=NGUYEN VAN A

# ===== Supabase Management API (chỉ dùng local để chạy scripts/run-sql.mjs) =====
# Tạo tại: https://supabase.com/dashboard/account/tokens
# KHÔNG cần đưa lên Vercel.
SUPABASE_ACCESS_TOKEN=sbp_your_personal_access_token

# ===== Admin Panel =====
# Mật khẩu để đăng nhập admin panel
NEXT_PUBLIC_ADMIN_PASSWORD=your_admin_password

# Secret key để xác thực API admin (sử dụng trong header Authorization)
ADMIN_SECRET_KEY=your_admin_secret_key

# URL webhook (hiển thị trong admin settings)
SEPAY_WEBHOOK_URL=https://yourdomain.com/api/sepay/webhook

# ===== Bank Information (hiển thị cho khách hàng) =====
BANK_CODE=ACB
BANK_ACCOUNT_NUMBER=your_bank_account_number
BANK_ACCOUNT_NAME=YOUR ACCOUNT NAME
