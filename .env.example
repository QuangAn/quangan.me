# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# ===== Supabase server (bắt buộc cho đăng ký + thanh toán tự động) =====
# Lấy tại: Supabase Dashboard > Project Settings > API > service_role
# TUYỆT ĐỐI không để lộ key này ra client / commit lên git.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===== SePay — thanh toán chuyển khoản tự động (https://sepay.vn) =====
# Chọn 1 trong 2 cách xác thực webhook (khớp với SePay > Cấu hình > Webhooks):
# (Khuyến nghị) HMAC-SHA256 — dán Secret Key (whsec_...) mà SePay cấp:
SEPAY_WEBHOOK_SECRET=whsec_your_sepay_signing_secret
# (Thay thế) API Key — SePay gửi header Authorization: Apikey <key>:
SEPAY_WEBHOOK_API_KEY=your_random_webhook_api_key

# Tài khoản ngân hàng nhận tiền — dùng để sinh mã QR VietQR và hiển thị cho khách
# (bỏ trống sẽ fallback về config/payment.ts). Tên chủ TK: IN HOA, KHÔNG DẤU.
SEPAY_BANK_CODE=ACB
SEPAY_ACCOUNT_NUMBER=your_bank_account_number
SEPAY_ACCOUNT_NAME=NGO QUANG AN

# ===== Supabase Management API (chỉ dùng local để chạy scripts/run-sql.mjs) =====
# Tạo tại: https://supabase.com/dashboard/account/tokens
# KHÔNG cần đưa lên Vercel.
SUPABASE_ACCESS_TOKEN=sbp_your_personal_access_token

# ===== Admin Panel =====
# Mật khẩu đăng nhập admin — kiểm PHÍA SERVER, KHÔNG để lộ ra client.
ADMIN_PASSWORD=your_admin_password

# Bí mật ký session admin (tuỳ chọn; bỏ trống sẽ dùng ADMIN_SECRET_KEY).
ADMIN_SESSION_SECRET=your_random_admin_session_secret

# Secret key admin — dùng cho tooling/CLI gọi API qua Bearer (tuỳ chọn).
ADMIN_SECRET_KEY=your_admin_secret_key

# URL webhook (hiển thị trong admin settings)
SEPAY_WEBHOOK_URL=https://yourdomain.com/api/sepay/webhook

# ===== Tài khoản học viên (tự cấp khi thanh toán) =====
# URL gốc của site — dùng để dựng link đăng nhập trong email cấp tài khoản.
# Không đặt cũng được (fallback về config/site.ts), nhưng nên set đúng domain.
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Bí mật ký session đăng nhập học viên (chuỗi ngẫu nhiên dài, tự đặt).
# Nếu bỏ trống sẽ tự dùng SUPABASE_SERVICE_ROLE_KEY. KHÔNG để lộ ra client.
STUDENT_SESSION_SECRET=your_random_long_secret

# ===== Gửi email (Resend — https://resend.com) =====
# API key để gửi email cấp tài khoản. Bỏ trống = KHÔNG gửi email thật
# (hệ thống vẫn tạo tài khoản, admin gửi lại sau khi cấu hình).
RESEND_API_KEY=your_resend_api_key

# Người gửi email. Domain phải được verify trong Resend.
# Khi test chưa có domain, Resend chỉ cho gửi tới email chủ tài khoản qua
# địa chỉ mặc định "onboarding@resend.dev".
EMAIL_FROM=AI Website Builder <no-reply@yourdomain.com>
